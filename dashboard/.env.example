# ---- Demo mode ----

# When true, the dashboard ignores Notion entirely and renders built-in
# sample content (lib/demo-data.ts). Use for sales previews before a client's
# tracker is connected. The header shows a "Preview / sample data" badge so
# it's never mistaken for real content. Leave unset (or false) in production.
DASHBOARD_DEMO_MODE=false

# ---- Notion connection (server-side only, never exposed to the browser) ----

# Internal integration token from https://www.notion.so/my-integrations
# The tracker database must be shared with this integration in Notion.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The id of the client's blog tracker database (or data source id).
# From the database URL: notion.so/workspace/<THIS_PART>?v=...
NOTION_BLOG_DB_ID=00000000000000000000000000000000

# ---- Per-client branding (one deploy per client, config only) ----

# Shown in the dashboard header.
CLIENT_NAME=Jane Doe Photography

# Optional market label under the client name.
CLIENT_CITY=Kansas City

# Accent color for this client. Any valid CSS color. Default: #00e5ff
CLIENT_ACCENT=#00e5ff

# Optional: the client's five content pillars, comma separated, in priority
# order. Pillars with zero posts then still show up as gaps. If unset, the
# pillar list is derived from the tracker data.
CLIENT_PILLARS=Corporate Headshots,Personal Branding,Studio Experience,Team Photography,Acting Headshots
